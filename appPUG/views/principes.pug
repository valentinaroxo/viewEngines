doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    title Príncipes

    style.
      body{
        font-family: Arial, sans-serif;
        background: linear-gradient(to right, #001f4d, #003366);
        text-align: center;
        margin: 0;
        padding: 0;
        color: white;
      }

      h1{
        margin-top: 30px;
        color: gold;
      }

      .container{
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 20px;
        margin: 40px;
      }

      .card{
        background-color: #00264d;
        border-radius: 15px;
        width: 220px;
        padding: 15px;
        box-shadow: 0px 4px 12px rgba(0,0,0,0.6);
        transition: transform 0.3s;
      }

      .card:hover{
        transform: scale(1.05);
      }

      .card img{
        width: 100%;
        border-radius: 10px;
      }

      .nome{
        font-size: 20px;
        color: gold;
        margin-top: 10px;
        font-weight: bold;
      }

      .descricao{
        font-size: 14px;
        color: #ddd;
      }

  body

    h1 🤴 Mundo dos Príncipes 🤴

    .container

      .card
        img(src="https://upload.wikimedia.org/wikipedia/en/7/7c/Prince_Eric.png")
        .nome Príncipe Eric
        .descricao O príncipe aventureiro que se apaixona por Ariel.

      .card
        img(src="https://upload.wikimedia.org/wikipedia/en/4/4c/Prince_Charming_Disney.png")
        .nome Príncipe Encantado
        .descricao O príncipe que encontra Cinderela pelo sapatinho de cristal.

      .card
        img(src="https://upload.wikimedia.org/wikipedia/en/9/9d/Prince_Adam_Beast.png")
        .nome Príncipe Adam
        .descricao O príncipe transformado em Fera até aprender o verdadeiro amor.

      .card
        img(src="https://upload.wikimedia.org/wikipedia/en/3/3a/Flynn_Rider_Tangled.png")
        .nome Flynn Rider
        .descricao Um ladrão charmoso que ajuda Rapunzel em sua aventura.