doctype html
html(lang="pt-br")
  head
    meta(charset="UTF-8")
    title Príncipes

    style.
      body{
        font-family: Arial, sans-serif;
        background: linear-gradient(to right, #001f4d, #003366);
        text-align: center;
        margin: 0;
        padding: 0;
        color: white;
      }

      h1{
        margin-top: 30px;
        color: gold;
      }
      h2 {
        font-family: sans-serif;
        color: #dad233;
        margin-bottom: 40px;
      }

      .container{
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 20px;
        margin: 40px;
      }

      .card{
        background-color: #00264d;
        border-radius: 15px;
        width: 220px;
        padding: 15px;
        box-shadow: 0px 4px 12px rgba(0,0,0,0.6);
        transition: transform 0.3s;
      }

      .card:hover{
        transform: scale(1.05);
      }

      .card img{
        width: 100%;
        height: 250px; 
        object-fit: cover;
        border-radius: 10px;
      }

      .nome{
        font-size: 20px;
        color: gold;
        margin-top: 10px;
        font-weight: bold;
      }

      .descricao{
        font-size: 14px;
        color: #ddd;
      }

  body

    h1  Mundo dos Príncipes 
    h2 "com esperança, vava!"


    .container

      .card
        img(src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSROlxTT7qwseBe93IUSDGhHmM4XurRNmO_1g&s")
        .nome Príncipe Eric
        .descricao O príncipe aventureiro que se apaixona por Ariel.

      .card
        img(src="https://cinepop.com.br/wp-content/uploads/2024/10/Charming_Profile.webp")
        .nome Príncipe Encantado
        .descricao O príncipe que encontra Cinderela pelo sapatinho de cristal.

      .card
        img(src="https://preview.redd.it/was-prince-naveen-indian-the-princess-and-the-frog-v0-k2g4oufa4bne1.jpg?width=736&format=pjpg&auto=webp&s=b9847962cd00f3b513be84ae65ef2bc255cf8f51")
        .nome Príncipe Naveen 
        .descricao O príncipe que é transformado em sapo e precisa da ajuda de Tiana para quebrar a maldição.

      .card
        img(src="https://i.pinimg.com/736x/e5/a6/36/e5a6361fa8a1a30a060c8021bae2e682.jpg")
        .nome Flynn Rider
        .descricao Um ladrão charmoso que ajuda Rapunzel em sua aventura.